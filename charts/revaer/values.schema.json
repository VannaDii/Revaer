{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": {
          "type": "string"
        }
      },
      "required": ["repository", "pullPolicy", "tag"]
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["name"]
      }
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string"
        },
        "existingSecret": {
          "type": "string"
        },
        "secretKey": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "secretAnnotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["url", "existingSecret", "secretKey", "secretAnnotations"]
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        }
      },
      "required": ["create", "annotations", "name"]
    },
    "podAnnotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "podLabels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "podSecurityContext": {
      "type": "object"
    },
    "containerSecurityContext": {
      "type": "object"
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "apiPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "uiPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "required": ["type", "annotations", "apiPort", "uiPort"]
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host": {
                "type": "string",
                "minLength": 1
              },
              "paths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "pathType": {
                      "type": "string",
                      "enum": ["Exact", "ImplementationSpecific", "Prefix"]
                    },
                    "servicePort": {
                      "type": "string",
                      "enum": ["api", "ui"]
                    }
                  },
                  "required": ["path", "pathType", "servicePort"]
                }
              }
            },
            "required": ["host", "paths"]
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "secretName": {
                "type": "string",
                "minLength": 1
              },
              "hosts": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "required": ["secretName", "hosts"]
          }
        }
      },
      "required": ["enabled", "className", "annotations", "hosts", "tls"]
    },
    "resources": {
      "type": "object"
    },
    "configPersistence": {
      "$ref": "#/definitions/persistence"
    },
    "dataPersistence": {
      "$ref": "#/definitions/persistence"
    },
    "extraEnv": {
      "type": "array",
      "items": {
        "type": "object",
        "minProperties": 1
      }
    },
    "extraEnvFrom": {
      "type": "array",
      "items": {
        "type": "object",
        "minProperties": 1
      }
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object"
    }
  },
  "required": [
    "replicaCount",
    "image",
    "imagePullSecrets",
    "nameOverride",
    "fullnameOverride",
    "database",
    "serviceAccount",
    "podAnnotations",
    "podLabels",
    "podSecurityContext",
    "containerSecurityContext",
    "service",
    "ingress",
    "resources",
    "configPersistence",
    "dataPersistence",
    "extraEnv",
    "extraEnvFrom",
    "nodeSelector",
    "tolerations",
    "affinity"
  ],
  "definitions": {
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "accessModes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "size": {
          "type": "string",
          "minLength": 1
        },
        "storageClassName": {
          "type": "string"
        },
        "existingClaim": {
          "type": "string"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "enabled",
        "accessModes",
        "size",
        "storageClassName",
        "existingClaim",
        "annotations"
      ]
    }
  }
}
