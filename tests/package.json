{
    "name": "revaer-playwright-tests",
    "private": true,
    "version": "0.1.0",
    "description": "Playwright E2E tests for Revaer UI",
    "scripts": {
        "gen:api-client": "openapi-typescript ../docs/api/openapi.json -o ./support/api/schema.ts",
        "test": "playwright test",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "codegen": "playwright codegen $E2E_BASE_URL",
        "playwright:install": "sudo ./node_modules/.bin/playwright install-deps && sudo ./node_modules/.bin/playwright install"
    },
    "devDependencies": {
        "@playwright/test": "1.58",
        "dotenv": "17.3",
        "openapi-fetch": "0.17",
        "openapi-typescript": "7.13"
    }
}
